#!/usr/bin/env bash

DEV_ENV="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

if [ -z "$XDG_CONFIG_HOME" ]; then
    echo "no xdg config home"
    echo "using ~/.config"
    XDG_CONFIG_HOME=$HOME/.config
fi

dry_run="0"
if [[ $1 == "--dry" ]]; then
    dry_run="1"
fi

log() {
    if [[ $dry_run == "1" ]]; then
        echo "[DRY_RUN]: $1"
    else
        echo "$1"
    fi
}

log "env: $DEV_ENV"

# Gather all config directories
configs=($(ls -d $DEV_ENV/env/.config/*/ 2>/dev/null | xargs -n1 basename))
configs+=("ALL")

echo "Available dev environments:"
selected=($(printf "%s\n" "${configs[@]}" | fzf --multi --prompt="Select configs to copy: "))

if [[ ${#selected[@]} -eq 0 ]]; then
    echo "No selection made. Exiting."
    exit 0
fi

if [[ " ${selected[*]} " =~ " ALL " ]]; then
    selected=("${configs[@]}")
    selected=("${selected[@]:0:$(( ${#selected[@]} - 1 ))}")
fi

failed=()

for choice in "${selected[@]}"; do
    src="$DEV_ENV/env/.config/$choice"
    dest="$XDG_CONFIG_HOME/$choice"

    if [[ ! -d "$src" ]]; then
        echo "Skipping $choice - not a directory"
        continue
    fi

    log "    removing: rm -rf $dest"
    if [[ $dry_run == "0" ]]; then
        rm -rf "$dest" 2>/dev/null
    fi

    log "    copying: $choice -> $XDG_CONFIG_HOME"
    if [[ $dry_run == "0" ]]; then
        if cp -r "$src" "$dest"; then
            echo "SUCCESS: $choice installed"
        else
            echo "FAILED: $choice"
            failed+=("$choice")
        fi
    fi
done

# Deploy .local/bin scripts
if [[ -d "$DEV_ENV/env/.local/bin" ]]; then
    log ""
    log "Deploying scripts to ~/.local/bin..."
    mkdir -p "$HOME/.local/bin"
    for script in "$DEV_ENV/env/.local/bin"/*; do
        [[ -f "$script" ]] || continue
        name=$(basename "$script")
        log "    copying: $name -> ~/.local/bin/"
        if [[ $dry_run == "0" ]]; then
            cp "$script" "$HOME/.local/bin/$name"
            chmod +x "$HOME/.local/bin/$name"
        fi
    done
fi

# Deploy shell dotfiles
log ""
log "Deploying shell dotfiles..."
for dotfile in bashrc zshrc tmux.conf; do
    src="$DEV_ENV/env/.$dotfile"
    dest="$HOME/.$dotfile"
    if [[ -f "$src" ]]; then
        log "    copying: .$dotfile -> ~/"
        if [[ $dry_run == "0" ]]; then
            cp "$src" "$dest"
        fi
    fi
done

if [[ ${#failed[@]} -gt 0 ]]; then
    echo ""
    echo "Failed installations: ${failed[*]}"
    echo "Fix the issues and re-run the script"
    exit 1
fi

echo ""
echo "All selected configs installed successfully!"
