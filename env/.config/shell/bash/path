# PATH additions
if [ -d "$HOME/.bin" ] ; then
  PATH="$HOME/.bin:$PATH"
fi

if [ -d "$HOME/.local/bin" ] ; then
  PATH="$HOME/.local/bin:$PATH"
fi

if [ -d "$HOME/.cargo/bin" ] ; then
  PATH="$HOME/.cargo/bin/:$PATH"
fi

if [ -d "/usr/local/go/bin/" ] ; then
  PATH="/usr/local/go/bin:$PATH"
fi

if [ -d "$HOME/go/bin/" ] ; then
  PATH="$HOME/go/bin/:$PATH"
fi

if [ -d "/opt/zig/" ] ; then
  PATH="/opt/zig/:$PATH"
fi
