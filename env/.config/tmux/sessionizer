# Sessionizer
bind-key -r f run-shell "tmux neww ~/.local/bin/tmux-sessionizer"
bind-key -r g display-popup -E "~/.local/bin/tmux-sessionizer -g"

bind-key -r N run-shell "~/.local/bin/tmux-sessionizer ~/Obsidian/Brain/Database/Notes"
bind-key -r E run-shell "~/.local/bin/tmux-sessionizer ~/Dev/personal"
bind-key -r W run-shell "~/.local/bin/tmux-sessionizer ~/Dev/work"
bind-key -r Q run-shell "~/.local/bin/tmux-sessionizer ~/Dev/projects"
