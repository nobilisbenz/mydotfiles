#!/usr/bin/env bash
script_dir="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"

dry_run="0"
if [[ $1 == "--dry" ]]; then
    dry_run="1"
fi

log() {
    if [[ $dry_run == "1" ]]; then
        echo "[DRY_RUN]: $1"
    else
        echo "$1"
    fi
}

runs=($(find $script_dir/runs -mindepth 1 -maxdepth 1 -executable -type f | sort))
run_names=($(for s in "${runs[@]}"; do basename "$s"; done))

echo "Available install scripts:"
selected=($(printf "%s\n" "${run_names[@]}" | fzf --multi --prompt="Select scripts to run: "))

if [[ ${#selected[@]} -eq 0 ]]; then
    echo "No selection made. Exiting."
    exit 0
fi

failed=()

for chosen in "${selected[@]}"; do
    for s in "${runs[@]}"; do
        if [[ "$(basename "$s")" == "$chosen" ]]; then
            log "running script: $s"
            
            if [[ $dry_run == "0" ]]; then
                if "$s"; then
                    echo "SUCCESS: $chosen completed"
                else
                    echo "FAILED: $chosen (exit code: $?)"
                    failed+=("$chosen")
                fi
            fi
            break
        fi
    done
done

if [[ ${#failed[@]} -gt 0 ]]; then
    echo ""
    echo "Failed scripts: ${failed[*]}"
    echo "Fix the issues and re-run the script"
    exit 1
fi

echo ""
echo "All selected scripts completed successfully!"
