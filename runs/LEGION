#!/usr/bin/env bash

# ──────────────────────────────────────────────
# Legion 5 RTX 3060 - Complete Automation
# ──────────────────────────────────────────────

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

print() { echo -e "${GREEN}:: $*${NC}"; }
warn()  { echo -e "${YELLOW}:: $*${NC}"; }
err()   { echo -e "${RED}:: $*${NC}"; }

# 1. Enable Multilib (Required for lib32-nvidia-utils)
if ! grep -q "^\[multilib\]" /etc/pacman.conf; then
    print "Enabling multilib repository..."
    sudo sed -i '/^#\[multilib\]/,/^#Include = \/etc\/pacman.d\/mirrorlist/ s/^#//' /etc/pacman.conf
    sudo pacman -Syu --noconfirm
fi

# 2. Core Drivers & Headers [cite: 3]
print "Installing NVIDIA drivers and kernel headers..."

retry_paru() {
    local max_attempts=3
    local attempt=1
    while [ $attempt -le $max_attempts ]; do
        if paru -S --needed --noconfirm "$@"; then
            return 0
        fi
        warn "Attempt $attempt failed, retrying in 5 seconds..."
        sleep 5
        attempt=$((attempt + 1))
    done
    err "Failed after $max_attempts attempts"
    return 1
}

retry_paru \
    linux-zen-headers \
    nvidia-dkms \
    nvidia-utils \
    lib32-nvidia-utils \
    nvidia-settings \
    egl-wayland \
    libva-nvidia-driver \
    nvidia-prime \
    envycontrol \
    libglvnd \
    opencl-nvidia

# 3. Automate Mkinitcpio (Early KMS)
print "Configuring Early KMS in mkinitcpio..."
if ! grep -q "nvidia nvidia_modeset nvidia_uvm nvidia_drm" /etc/mkinitcpio.conf; then
    sudo sed -i 's/^MODULES=(/MODULES=(nvidia nvidia_modeset nvidia_uvm nvidia_drm /' /etc/mkinitcpio.conf
    sudo mkinitcpio -P
fi

# Reinstall DKMS for Zen kernel (critical after headers update)
print "Reinstalling NVIDIA DKMS for current kernel..."
sudo dkms autoinstall 2>/dev/null || sudo nvidia-smi 2>/dev/null || true

# 4. Automate Kernel Parameters 
PARAM="nvidia-drm.modeset=1"

# Check for GRUB
if [ -f /etc/default/grub ]; then
    print "Automating GRUB kernel parameters..."
    if ! grep -q "$PARAM" /etc/default/grub; then
        sudo sed -i "/GRUB_CMDLINE_LINUX_DEFAULT/ s/\"$/ $PARAM\"/" /etc/default/grub
        sudo grub-mkconfig -o /boot/grub/grub.cfg
    fi
# Check for systemd-boot
elif [ -d /boot/loader/entries/ ]; then
    print "Automating systemd-boot kernel parameters..."
    for entry in /boot/loader/entries/*.conf; do
        if ! grep -q "$PARAM" "$entry"; then
            sudo sed -i "/^options/ s/$/ $PARAM/" "$entry"
        fi
    done
fi

# 5. Set Hybrid Mode (MUST load driver BEFORE nvidia-persistenced)
print "Setting graphics to Hybrid mode..."
sudo envycontrol -s hybrid

print "Loading NVIDIA kernel modules..."
sudo modprobe nvidia nvidia_modeset nvidia_uvm nvidia_drm 2>/dev/null || true
sleep 3

# 6. Stabilization & Power [cite: 4]
print "Enabling persistence and power management..."

current_mode=$(sudo envycontrol -s 2>/dev/null | grep -i mode | head -1 || echo "")
if [[ "$current_mode" == *"nvidia"* ]] || [[ "$current_mode" == *"hybrid"* && -e /dev/nvidia0 ]]; then
    sudo systemctl enable --now nvidia-persistenced || warn "nvidia-persistenced failed - may require reboot"
fi
sudo systemctl enable --now power-profiles-daemon
if systemctl list-unit-files thermald.service &>/dev/null; then
    sudo systemctl enable --now thermald
fi

# 7. Verify GPU Detection
print "Verifying GPU detection..."
sleep 2

GPU_DETECTED=$(lspci | grep -iE "VGA.*3060|GeForce.*30" || nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null || echo "")

if [ -n "$GPU_DETECTED" ]; then
    print "GPU detected: $GPU_DETECTED"
    nvidia-smi --query-gpu=name,driver_version,power.limit --format=csv
else
    err "GPU NOT detected! Check secure boot, fast boot, or kernel mode settings in BIOS"
    warn "If using hybrid mode, reboot and wait for nvidia-drm to load"
    warn "Also run: lsmod | grep nvidia to verify modules loaded"
fi

# 8. Install nvtop for monitoring
print "Installing nvtop for GPU monitoring..."
retry_paru nvtop 2>/dev/null || sudo pacman -S --noconfirm nvtop 2>/dev/null || true

print "Automation complete. Reboot required for drivers to load properly."
