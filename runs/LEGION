#!/usr/bin/env bash

# Define color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

print_color() {
    local color="$1"
    shift
    echo -e "${color}$*${NC}"
}

print_color $GREEN "🚀 Starting Legion 5 (RTX 3060) Wayland Setup..."

# 1. NVIDIA Drivers & Wayland Essentials
# 'nvidia-dkms' is correct for the custom kernel/Legion hardware.
# 'egl-wayland' is critical for NVIDIA + Wayland stability.
print_color $YELLOW "Installing NVIDIA drivers and Wayland bridges..."
paru -S --needed --noconfirm \
    nvidia-dkms \
    nvidia-utils \
    nvidia-settings \
    egl-wayland \
    libva-nvidia-driver

# 2. Modern Laptop Power Management
# We use power-profiles-daemon because it integrates with Waybar/KDE/Gnome UI.
# 'thermald' prevents your Legion from thermal throttling too aggressively.
print_color $YELLOW "Configuring power and thermal management..."
sudo pacman -S --needed --noconfirm \
    power-profiles-daemon \
    thermald \
    acpi \
    brightnessctl

# Enable services
sudo systemctl enable --now power-profiles-daemon
sudo systemctl enable --now thermald

# 3. Modern Input (Wayland uses libinput, not Synaptics)
print_color $YELLOW "Setting up input drivers..."
sudo pacman -S --needed --noconfirm libinput

# 4. Critical NVIDIA Kernel Modesetting
# Without this, Hyprland/Wayland may boot to a black screen.
print_color $RED "IMPORTANT: Ensure 'nvidia_drm.modeset=1' is in your GRUB/systemd-boot parameters!"

print_color $GREEN "✅ Installation completed. Please reboot to apply NVIDIA kernel changes."
