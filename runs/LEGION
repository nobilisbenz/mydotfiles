#!/usr/bin/env bash

# ──────────────────────────────────────────────
# Legion 5 RTX 3060 - NVIDIA + Wayland extras
# Run AFTER the base 'dev' script
# ──────────────────────────────────────────────

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

print() { echo -e "${GREEN}:: $*${NC}"; }
warn()  { echo -e "${YELLOW}:: $*${NC}"; }
err()   { echo -e "${RED}:: $*${NC}"; }

# ──────────────────────────────────────────────
# NVIDIA Drivers
# ──────────────────────────────────────────────

print "Installing NVIDIA drivers..."
paru -S --needed --noconfirm \
    nvidia-dkms \
    nvidia-utils \
    nvidia-settings \
    egl-wayland \
    libva-nvidia-driver

# ──────────────────────────────────────────────
# Hyprland NVIDIA environment
# ──────────────────────────────────────────────

print "Writing NVIDIA env config for Hyprland..."
mkdir -p ~/.config/hypr
cat > ~/.config/hypr/nvidia.conf << 'EOF'
# NVIDIA-specific environment variables
# This file is sourced by hyprland.conf on NVIDIA machines

env = LIBVA_DRIVER_NAME,nvidia
env = __GLX_VENDOR_LIBRARY_NAME,nvidia
env = NVD_BACKEND,direct
EOF

# Add source line to hyprland.conf if not already present
HYPR_CONF="$HOME/.config/hypr/hyprland.conf"
if [ -f "$HYPR_CONF" ] && ! grep -q "nvidia.conf" "$HYPR_CONF"; then
    # Insert after the env block
    echo -e "\n# NVIDIA (auto-added by LEGION script)\nsource = ~/.config/hypr/nvidia.conf" >> "$HYPR_CONF"
    print "Added nvidia.conf source to hyprland.conf"
fi

# ──────────────────────────────────────────────
# Power & Thermal Management
# ──────────────────────────────────────────────

print "Installing power management..."
paru -S --needed --noconfirm \
    power-profiles-daemon \
    thermald

sudo systemctl enable --now power-profiles-daemon
sudo systemctl enable --now thermald

# ──────────────────────────────────────────────
# Input drivers
# ──────────────────────────────────────────────

paru -S --needed --noconfirm libinput

# ──────────────────────────────────────────────
# Kernel parameter reminder
# ──────────────────────────────────────────────

err "IMPORTANT: Ensure 'nvidia_drm.modeset=1' is in your kernel parameters!"
err "  For GRUB: edit /etc/default/grub -> GRUB_CMDLINE_LINUX_DEFAULT"
err "  For systemd-boot: edit /boot/loader/entries/*.conf"
echo ""
print "NVIDIA setup complete. Reboot to apply kernel changes."
