#!/usr/bin/env bash

# ──────────────────────────────────────────────
# Shell tools, fonts, and prompt setup
# ──────────────────────────────────────────────

set -e

GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

print() { echo -e "${GREEN}:: $*${NC}"; }
warn()  { echo -e "${YELLOW}:: $*${NC}"; }

# Starship prompt
if ! command -v starship &>/dev/null; then
    print "Installing Starship..."
    curl -sS https://starship.rs/install.sh | sh -s -- -y
else
    warn "Starship already installed"
fi

# Tmux Plugin Manager
if [ ! -d "$HOME/.tmux/plugins/tpm" ]; then
    print "Installing Tmux Plugin Manager..."
    git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
else
    warn "TPM already installed"
fi

# FiraCodeiScript font
if [ ! -d "$HOME/.local/share/fonts/FiraCodeiScript" ]; then
    print "Installing Fira Code iScript..."
    mkdir -p ~/.local/share/fonts
    git clone https://github.com/kencrocken/FiraCodeiScript.git ~/.local/share/fonts/FiraCodeiScript
    fc-cache -fv
else
    warn "Fira Code iScript already installed"
fi

print "Shell setup complete!"
